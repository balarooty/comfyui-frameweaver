        "class_type": "SaveImage",
        "inputs": {
          "images": [
            "23",
            0
          ],
          "filename_prefix": "FrameWeaver/postprocessed"
        }
      },
      "40": {
        "_meta": {
          "title": "FW_LUTCreate"
        },
        "class_type": "FW_LUTCreate",
